---
import { AboutContent } from "../components/about/about-content.tsx";
import { ThemeToggle } from "../components/theme-toggle/theme-toggle.tsx";
import BaseLayout from "../layouts/base.astro";
---
<BaseLayout title="About HN Pulse" description="Methodology, data sources and KPI definitions for HN Pulse.">
  <header class="sticky top-0 z-10 border-b bg-background/80 backdrop-blur">
    <div class="mx-auto max-w-6xl flex items-center justify-between px-4 py-3">
      <a href="/1m" class="font-semibold text-lg">HN Pulse</a>
      <div class="flex items-center gap-3">
        <ThemeToggle client:load />
        <a href="/1m" class="text-sm text-muted-foreground hover:text-foreground">Dashboard</a>
      </div>
    </div>
  </header>
  <AboutContent />
</BaseLayout>
