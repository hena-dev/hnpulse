---
import { readFileSync } from "node:fs";
import { join } from "node:path";
import { DetailCharts } from "../components/dashboard/detail-charts.tsx";
import { KpiGrid } from "../components/dashboard/kpi-grid.tsx";
import { ThemeToggle } from "../components/theme-toggle/theme-toggle.tsx";
import { parseKpis, parseMeta } from "../data/schema.ts";
import BaseLayout from "../layouts/base.astro";
import { buildDashboardData } from "../lib/dashboard-data.ts";
import { RANGE_IDS, type RangeId } from "../lib/range/range.ts";

export const getStaticPaths = () =>
  RANGE_IDS.map((range) => ({
    params: { range },
    props: { range },
  }));

interface Props {
  range: RangeId;
}

const { range } = Astro.props as Props;
const dataDir = join(process.cwd(), "public", "data");
const meta = parseMeta(JSON.parse(readFileSync(join(dataDir, "meta.json"), "utf8")));
const kpisFileName = meta.kpisFile.replace(/^\/data\//, "");
const kpis = parseKpis(JSON.parse(readFileSync(join(dataDir, kpisFileName), "utf8")));
const dashboard = buildDashboardData(kpis, range);
---
<BaseLayout title="HN Pulse — Hacker News, daily vitals" description="A daily-updated dashboard of Hacker News' most important community vitals: submissions, comments, active users, top domains, and more.">
  <header class="sticky top-0 z-10 border-b bg-background/80 backdrop-blur">
    <div class="mx-auto max-w-6xl flex items-center justify-between px-4 py-3">
      <a href="/1m" data-astro-prefetch="load" class="font-semibold text-lg">HN Pulse</a>
      <div class="flex items-center gap-3">
        <ThemeToggle client:load />
        <a href="https://github.com/hena-dev/hnpulse" target="_blank" rel="noopener" class="text-sm text-muted-foreground hover:text-foreground">GitHub</a>
        <a href="/about" data-astro-prefetch="load" class="text-sm text-muted-foreground hover:text-foreground">About</a>
      </div>
    </div>
  </header>
  <main class="mx-auto max-w-6xl px-4 py-6 flex flex-col gap-6">
    <KpiGrid summaries={dashboard.summaries} topDomain={dashboard.topDomain} meta={meta} range={range} />
    <DetailCharts series={dashboard.detailSeries} topDomains={dashboard.topDomains} client:load transition:persist="detail-charts" />
  </main>
  <footer class="mx-auto max-w-6xl px-4 py-8 text-xs text-muted-foreground">
    Built by hena · <a href="https://github.com/hena-dev/hnpulse" class="underline">Repo</a> · last updated {meta.lastUpdated}
  </footer>
</BaseLayout>
